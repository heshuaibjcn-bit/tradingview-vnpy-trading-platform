# Energy Storage Investment Decision System - Environment Configuration

# API Configuration
APP_NAME=Energy Storage Investment Decision API
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Calculation Parameters
DEFAULT_PROJECT_LIFETIME_YEARS=15
DEFAULT_DISCOUNT_RATE=0.08
DEFAULT_INFLATION_RATE=0.03

# Report Configuration
REPORT_FONT=Helvetica
REPORT_FONT_SIZE=10
REPORT_TITLE_SIZE=18
